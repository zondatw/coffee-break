#!/usr/bin/env bash
# setup — install coffee-break skill for Claude Code and/or Codex
set -e

REPO_DIR="$(cd "$(dirname "$0")" && pwd)"

# ─── Parse flags ──────────────────────────────────────────────
HOST="auto"
while [ $# -gt 0 ]; do
  case "$1" in
    --host) HOST="$2"; shift 2 ;;
    --host=*) HOST="${1#--host=}"; shift ;;
    *) shift ;;
  esac
done

case "$HOST" in
  claude|codex|auto) ;;
  *) echo "Unknown --host value: $HOST (expected claude, codex, or auto)" >&2; exit 1 ;;
esac

INSTALL_CLAUDE=0
INSTALL_CODEX=0

if [ "$HOST" = "auto" ]; then
  command -v claude >/dev/null 2>&1 && INSTALL_CLAUDE=1
  command -v codex  >/dev/null 2>&1 && INSTALL_CODEX=1
  [ "$INSTALL_CLAUDE" -eq 0 ] && [ "$INSTALL_CODEX" -eq 0 ] && INSTALL_CLAUDE=1
elif [ "$HOST" = "claude" ]; then
  INSTALL_CLAUDE=1
elif [ "$HOST" = "codex" ]; then
  INSTALL_CODEX=1
fi

# ─── Claude Code ──────────────────────────────────────────────
if [ "$INSTALL_CLAUDE" -eq 1 ]; then
  CLAUDE_SKILLS="$HOME/.claude/skills"
  SKILL_LINK="$CLAUDE_SKILLS/coffee-break"
  mkdir -p "$CLAUDE_SKILLS"

  if [ -L "$SKILL_LINK" ]; then
    rm "$SKILL_LINK"
  elif [ -d "$SKILL_LINK" ]; then
    echo "Error: $SKILL_LINK is a real directory. Remove it manually and rerun." >&2
    exit 1
  fi

  ln -s "$REPO_DIR" "$SKILL_LINK"
  echo "coffee-break ready (claude)."
  echo "  skill: $SKILL_LINK"
fi

# ─── Codex ────────────────────────────────────────────────────
if [ "$INSTALL_CODEX" -eq 1 ]; then
  CODEX_SKILLS="$HOME/.codex/skills"
  SKILL_DIR="$CODEX_SKILLS/coffee-break"
  mkdir -p "$SKILL_DIR"

  # Rewrite ${CLAUDE_SKILL_DIR} → absolute repo path for Codex
  sed "s|\${CLAUDE_SKILL_DIR}|$REPO_DIR|g" "$REPO_DIR/SKILL.md" > "$SKILL_DIR/SKILL.md"

  # Symlink bin/ so the script is reachable at the rewritten path
  if [ -L "$SKILL_DIR/bin" ] || [ ! -e "$SKILL_DIR/bin" ]; then
    ln -snf "$REPO_DIR/bin" "$SKILL_DIR/bin"
  fi

  echo "coffee-break ready (codex)."
  echo "  skill: $SKILL_DIR"
fi
