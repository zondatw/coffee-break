#!/usr/bin/env bash
# setup — install coffee-break skill for Claude Code and/or Codex
set -e

REPO_DIR="$(cd "$(dirname "$0")" && pwd)"

# ─── Parse flags ──────────────────────────────────────────────
HOST="auto"
while [ $# -gt 0 ]; do
  case "$1" in
    --host) HOST="$2"; shift 2 ;;
    --host=*) HOST="${1#--host=}"; shift ;;
    *) shift ;;
  esac
done

case "$HOST" in
  claude|codex|auto) ;;
  *) echo "Unknown --host value: $HOST (expected claude, codex, or auto)" >&2; exit 1 ;;
esac

INSTALL_CLAUDE=0
INSTALL_CODEX=0

if [ "$HOST" = "auto" ]; then
  command -v claude >/dev/null 2>&1 && INSTALL_CLAUDE=1
  command -v codex  >/dev/null 2>&1 && INSTALL_CODEX=1
  [ "$INSTALL_CLAUDE" -eq 0 ] && [ "$INSTALL_CODEX" -eq 0 ] && INSTALL_CLAUDE=1
elif [ "$HOST" = "claude" ]; then
  INSTALL_CLAUDE=1
elif [ "$HOST" = "codex" ]; then
  INSTALL_CODEX=1
fi

# ─── Claude Code ──────────────────────────────────────────────
if [ "$INSTALL_CLAUDE" -eq 1 ]; then
  CLAUDE_SKILLS="$HOME/.claude/skills"
  SKILL_LINK="$CLAUDE_SKILLS/coffee-break"
  mkdir -p "$CLAUDE_SKILLS"

  if [ -L "$SKILL_LINK" ]; then
    rm "$SKILL_LINK"
  elif [ -d "$SKILL_LINK" ]; then
    echo "Error: $SKILL_LINK is a real directory. Remove it manually and rerun." >&2
    exit 1
  fi

  ln -s "$REPO_DIR" "$SKILL_LINK"
  echo "coffee-break ready (claude)."
  echo "  skill: $SKILL_LINK"
fi

# ─── Codex ────────────────────────────────────────────────────
if [ "$INSTALL_CODEX" -eq 1 ]; then
  CODEX_SKILLS="$HOME/.codex/skills"
  SKILL_DIR="$CODEX_SKILLS/coffee-break"
  mkdir -p "$SKILL_DIR"

  # Generate codex SKILL.md: stripped frontmatter (name + description only),
  # no allowed-tools/version, and absolute path replacing ${CLAUDE_SKILL_DIR}
  cat << 'CODEX_SKILL' | sed "s|__REPO_DIR__|$REPO_DIR|g" > "$SKILL_DIR/SKILL.md"
---
name: coffee-break
description: |
  Coffee break for the AI agent — because even agents need rest! Shows an
  animated ASCII coffee cup while the agent takes a timed break. User can set
  the duration (default 5 minutes). Use when asked to "take a break",
  "coffee break", "rest", "pause", or "coffee time".
---

# /coffee-break — Time to Rest ☕

The agent is taking a well-deserved coffee break. Parse the duration from the
user's message (e.g. "5 minutes", "2m", "30s", "1 min") — default to **5 minutes**
if none given.

Run this Bash command directly — the script finds the terminal TTY and
renders the animation right there, no new window needed:

```bash
bash __REPO_DIR__/bin/coffee-break.sh <DURATION_SECONDS>
```

Where `<DURATION_SECONDS>` is the duration converted to seconds (integer).

After the script finishes, greet the user back:
"Back and refreshed! ☕ Ready to get back to work."
CODEX_SKILL

  # Symlink bin/ so the script is reachable at the rewritten path
  if [ -L "$SKILL_DIR/bin" ] || [ ! -e "$SKILL_DIR/bin" ]; then
    ln -snf "$REPO_DIR/bin" "$SKILL_DIR/bin"
  fi

  echo "coffee-break ready (codex)."
  echo "  skill: $SKILL_DIR"
fi
